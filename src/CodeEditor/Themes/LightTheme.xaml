<!-- Ember Light ("Parchment") theme (see docs/DESIGN.md): warm paper, ink text, deep copper accent.
     Every theme dictionary must define this exact set of brush keys. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ====== Ember semantic tokens (new chrome consumes these) ====== -->

    <SolidColorBrush x:Key="Brush.Canvas" Color="#EDE7DC" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#F8F4EC" />
    <SolidColorBrush x:Key="Brush.Surface.Editor" Color="#FFFCF5" />
    <SolidColorBrush x:Key="Brush.Surface.Overlay" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Surface.Sunken" Color="#F0EBE1" />
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="#DFD7C9" />
    <SolidColorBrush x:Key="Brush.Border.Strong" Color="#C9BFAE" />
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#33291F" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#6E6252" />
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="#91846F" />
    <SolidColorBrush x:Key="Brush.Accent.Hover" Color="#C96F41" />
    <SolidColorBrush x:Key="Brush.Accent.Soft" Color="#F3DFCE" />
    <SolidColorBrush x:Key="Brush.Hover" Color="#EFE8DB" />
    <SolidColorBrush x:Key="Brush.Selected" Color="#E9DFCE" />
    <SolidColorBrush x:Key="Brush.Text.OnColor" Color="#FFFFFF" />

    <!-- ====== Established keys, re-pointed to Ember values ====== -->

    <SolidColorBrush x:Key="Brush.Window.Background" Color="#EDE7DC" />
    <SolidColorBrush x:Key="Brush.Window.Foreground" Color="#33291F" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#B65C2E" />

    <SolidColorBrush x:Key="Brush.Menu.Background" Color="#EDE7DC" />
    <SolidColorBrush x:Key="Brush.Menu.Popup.Background" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Menu.Popup.Border" Color="#C9BFAE" />
    <SolidColorBrush x:Key="Brush.Menu.Item.Hover" Color="#F3EDE2" />

    <SolidColorBrush x:Key="Brush.Toolbar.Background" Color="#EDE7DC" />
    <SolidColorBrush x:Key="Brush.Toolbar.Button.Hover" Color="#E2DACB" />
    <SolidColorBrush x:Key="Brush.Toolbar.Button.Pressed" Color="#F3DFCE" />

    <SolidColorBrush x:Key="Brush.Panel.Background" Color="#F8F4EC" />
    <SolidColorBrush x:Key="Brush.Panel.Border" Color="#DFD7C9" />
    <SolidColorBrush x:Key="Brush.Panel.Header.Foreground" Color="#6E6252" />

    <SolidColorBrush x:Key="Brush.StatusBar.Background" Color="#EDE7DC" />
    <SolidColorBrush x:Key="Brush.StatusBar.Foreground" Color="#6E6252" />

    <SolidColorBrush x:Key="Brush.Tab.Strip.Background" Color="#F8F4EC" />
    <SolidColorBrush x:Key="Brush.Tab.Background" Color="#F8F4EC" />
    <SolidColorBrush x:Key="Brush.Tab.Foreground" Color="#6E6252" />
    <SolidColorBrush x:Key="Brush.Tab.Active.Background" Color="#FFFCF5" />
    <SolidColorBrush x:Key="Brush.Tab.Active.Foreground" Color="#33291F" />
    <SolidColorBrush x:Key="Brush.Tab.Hover.Background" Color="#EFE8DB" />

    <SolidColorBrush x:Key="Brush.Editor.Background" Color="#FFFCF5" />
    <SolidColorBrush x:Key="Brush.Editor.Foreground" Color="#33291F" />
    <SolidColorBrush x:Key="Brush.Editor.LineNumber" Color="#9A8D7B" />
    <SolidColorBrush x:Key="Brush.Editor.CurrentLine" Color="#F6F0E4" />
    <SolidColorBrush x:Key="Brush.Editor.Selection" Color="#F0DBC2" />
    <SolidColorBrush x:Key="Brush.Editor.FindMatch.Highlight" Color="#40B65C2E" />
    <SolidColorBrush x:Key="Brush.Editor.FindMatch.Current" Color="#F5DEB9" />

    <!-- Syntax: metallurgy — ember keywords, patina types, brass methods (DESIGN.md) -->
    <SolidColorBrush x:Key="Brush.Syntax.Keyword" Color="#B65C2E" />
    <SolidColorBrush x:Key="Brush.Syntax.ControlKeyword" Color="#B04455" />
    <SolidColorBrush x:Key="Brush.Syntax.Preprocessor" Color="#8A7E70" />
    <SolidColorBrush x:Key="Brush.Syntax.Type" Color="#37806F" />
    <SolidColorBrush x:Key="Brush.Syntax.Method" Color="#8F6B2A" />
    <SolidColorBrush x:Key="Brush.Syntax.Variable" Color="#5C4F3D" />
    <SolidColorBrush x:Key="Brush.Syntax.String" Color="#6D7F3E" />
    <SolidColorBrush x:Key="Brush.Syntax.Number" Color="#A06A2C" />
    <SolidColorBrush x:Key="Brush.Syntax.Comment" Color="#968871" />

    <SolidColorBrush x:Key="Brush.Diagnostic.Error" Color="#C33C2E" />
    <SolidColorBrush x:Key="Brush.Diagnostic.Warning" Color="#A5751B" />
    <SolidColorBrush x:Key="Brush.Diagnostic.Info" Color="#3C7F78" />

    <SolidColorBrush x:Key="Brush.Tree.Item.Hover" Color="#EFE8DB" />
    <SolidColorBrush x:Key="Brush.Tree.Item.Selected.Background" Color="#E9DFCE" />
    <SolidColorBrush x:Key="Brush.Tree.Item.Selected.Foreground" Color="#33291F" />

    <SolidColorBrush x:Key="Brush.Control.Border" Color="#DFD7C9" />

</ResourceDictionary>

<Window x:Class="CodeEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:CodeEditor.Views"
        xmlns:vm="clr-namespace:CodeEditor.ViewModels"
        xmlns:services="clr-namespace:CodeEditor.Services"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="{Binding Title}"
        Width="1280"
        Height="800"
        MinWidth="640"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Window.Background}"
        Foreground="{DynamicResource Brush.Window.Foreground}">

    <!-- Custom chrome: the 40px top bar is the caption (drag, double-click, snap);
         interactive children opt out via WindowChrome.IsHitTestVisibleInChrome. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding Documents.NewDocumentCommand}" />
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding Documents.OpenFileCommand}" />
        <KeyBinding Modifiers="Control+Shift" Key="O" Command="{Binding Explorer.OpenFolderCommand}" />
        <KeyBinding Modifiers="Control+Shift" Key="F" Command="{Binding FindInFilesCommand}" />
        <KeyBinding Modifiers="Control" Key="F" Command="{Binding Find.OpenFindCommand}" />
        <KeyBinding Modifiers="Control" Key="H" Command="{Binding Find.OpenReplaceCommand}" />
        <KeyBinding Key="F3" Command="{Binding Find.FindNextCommand}" />
        <KeyBinding Modifiers="Shift" Key="F3" Command="{Binding Find.FindPreviousCommand}" />
        <KeyBinding Key="F12" Command="{Binding GoToDefinitionCommand}" />
        <KeyBinding Modifiers="Shift" Key="F12" Command="{Binding FindAllReferencesCommand}" />
        <KeyBinding Key="F2" Command="{Binding RenameSymbolCommand}" />
        <KeyBinding Modifiers="Shift+Alt" Key="F" Command="{Binding FormatDocumentCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding Documents.SaveActiveCommand}" />
        <KeyBinding Modifiers="Control+Shift" Key="S" Command="{Binding Documents.SaveActiveAsCommand}" />
        <KeyBinding Modifiers="Control+Alt" Key="S" Command="{Binding Documents.SaveAllCommand}" />
        <KeyBinding Modifiers="Control" Key="W" Command="{Binding Documents.CloseActiveCommand}" />
        <KeyBinding Modifiers="Control" Key="OemPlus" Command="{Binding Options.ZoomInCommand}" />
        <KeyBinding Modifiers="Control" Key="Add" Command="{Binding Options.ZoomInCommand}" />
        <KeyBinding Modifiers="Control" Key="OemMinus" Command="{Binding Options.ZoomOutCommand}" />
        <KeyBinding Modifiers="Control" Key="Subtract" Command="{Binding Options.ZoomOutCommand}" />
        <KeyBinding Modifiers="Control" Key="D0" Command="{Binding Options.ResetZoomCommand}" />
        <KeyBinding Modifiers="Control" Key="NumPad0" Command="{Binding Options.ResetZoomCommand}" />
    </Window.InputBindings>

    <DockPanel x:Name="RootLayout">

        <!-- ============================= Top bar (custom window chrome) ============================= -->
        <Grid DockPanel.Dock="Top" Height="40" Background="{DynamicResource Brush.Canvas}">

            <!-- App mark + menus -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Margin="14,0,0,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Border Width="16"
                        Height="16"
                        CornerRadius="4"
                        Background="{DynamicResource Brush.Accent}"
                        VerticalAlignment="Center" />
                <Menu Background="Transparent" VerticalAlignment="Center" Margin="8,0,0,0">
            <MenuItem Header="_File">
                <MenuItem Header="_New File" Command="{Binding Documents.NewDocumentCommand}" InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open File…" Command="{Binding Documents.OpenFileCommand}" InputGestureText="Ctrl+O" />
                <MenuItem Header="Open Fol_der…" Command="{Binding Explorer.OpenFolderCommand}" InputGestureText="Ctrl+Shift+O" />
                <MenuItem Header="Open _Recent" ItemsSource="{Binding RecentFiles}" IsEnabled="{Binding HasRecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Header" Value="{Binding Path}" />
                            <Setter Property="Command" Value="{Binding OpenCommand}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Save" Command="{Binding Documents.SaveActiveCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As…" Command="{Binding Documents.SaveActiveAsCommand}" InputGestureText="Ctrl+Shift+S" />
                <MenuItem Header="Save A_ll" Command="{Binding Documents.SaveAllCommand}" InputGestureText="Ctrl+Alt+S" />
                <Separator />
                <MenuItem Header="_Close Tab" Command="{Binding Documents.CloseActiveCommand}" InputGestureText="Ctrl+W" />
                <MenuItem Header="Close Fol_der" Command="{Binding Explorer.CloseFolderCommand}" />
                <Separator />
                <MenuItem Header="Se_ttings" Command="{Binding OpenSettingsFileCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" InputGestureText="Alt+F4" />
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="Undo" />
                <MenuItem Header="_Redo" Command="Redo" />
                <Separator />
                <MenuItem Header="Cu_t" Command="Cut" />
                <MenuItem Header="_Copy" Command="Copy" />
                <MenuItem Header="_Paste" Command="Paste" />
                <Separator />
                <MenuItem Header="Select _All" Command="SelectAll" />
                <Separator />
                <MenuItem Header="_Find…" Command="{Binding Find.OpenFindCommand}" InputGestureText="Ctrl+F" />
                <MenuItem Header="R_eplace…" Command="{Binding Find.OpenReplaceCommand}" InputGestureText="Ctrl+H" />
                <MenuItem Header="Find in F_iles…" Command="{Binding FindInFilesCommand}" InputGestureText="Ctrl+Shift+F" />
                <Separator />
                <MenuItem Header="_Go to Definition" Command="{Binding GoToDefinitionCommand}" InputGestureText="F12" />
                <MenuItem Header="Find All Re_ferences" Command="{Binding FindAllReferencesCommand}" InputGestureText="Shift+F12" />
                <MenuItem Header="Re_name Symbol…" Command="{Binding RenameSymbolCommand}" InputGestureText="F2" />
                <MenuItem Header="Forma_t Document" Command="{Binding FormatDocumentCommand}" InputGestureText="Shift+Alt+F" />
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="_Word Wrap" IsCheckable="True" IsChecked="{Binding Options.WordWrap, Mode=TwoWay}" />
                <MenuItem Header="_Line Numbers" IsCheckable="True" IsChecked="{Binding Options.ShowLineNumbers, Mode=TwoWay}" />
                <Separator />
                <MenuItem Header="Zoom _In" Command="{Binding Options.ZoomInCommand}" InputGestureText="Ctrl++" />
                <MenuItem Header="Zoom _Out" Command="{Binding Options.ZoomOutCommand}" InputGestureText="Ctrl+-" />
                <MenuItem Header="_Reset Zoom" Command="{Binding Options.ResetZoomCommand}" InputGestureText="Ctrl+0" />
                <Separator />
                <MenuItem Header="_Theme" ItemsSource="{Binding ThemeOptions}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Header" Value="{Binding DisplayName}" />
                            <Setter Property="Command" Value="{Binding SelectCommand}" />
                            <Setter Property="IsChecked" Value="{Binding IsSelected, Mode=OneWay}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator />
                <MenuItem Header="Show _Sidebar" IsCheckable="True" IsChecked="{Binding IsSidebarVisible, Mode=TwoWay}" />
                <MenuItem Header="Show _Bottom Panel" IsCheckable="True" IsChecked="{Binding IsBottomPanelVisible, Mode=TwoWay}" />
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About Code Editor" Command="{Binding AboutCommand}" />
            </MenuItem>
                </Menu>
            </StackPanel>

            <!-- Centered workspace pill -->
            <Button Style="{StaticResource WorkspacePillStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="360"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Command="{Binding Explorer.OpenFolderCommand}"
                    ToolTip="{Binding Explorer.RootPath, TargetNullValue='Open Folder (Ctrl+Shift+O)'}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8B7;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Muted}" />
                    <TextBlock Margin="7,0,0,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               Text="{Binding Explorer.RootName, TargetNullValue='Open a folder'}" />
                </StackPanel>
            </Button>

            <!-- Window controls -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource WindowControlButtonStyle}" Content="&#xE921;" ToolTip="Minimize" Click="OnMinimizeClick" />
                <Button Style="{StaticResource WindowMaximizeButtonStyle}" Click="OnMaximizeRestoreClick" />
                <Button Style="{StaticResource WindowCloseButtonStyle}" Content="&#xE8BB;" ToolTip="Close" Click="OnCloseWindowClick" />
            </StackPanel>
        </Grid>

        <!-- ============================= Status footer (transparent, pill indicators) ============================= -->
        <Border DockPanel.Dock="Bottom" Background="Transparent" Padding="16,5,14,7">
            <Grid>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource Brush.StatusBar.Foreground}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="0,0,320,0" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Documents.ActiveDocument}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.StatusBar.Foreground}" />
                            <Setter Property="FontSize" Value="11" />
                        </Style>
                    </StackPanel.Resources>
                    <Border Style="{StaticResource StatusPillStyle}">
                        <TextBlock Text="{Binding Documents.ActiveDocument.Language.DisplayName}" />
                    </Border>
                    <Border Style="{StaticResource StatusPillStyle}">
                        <TextBlock>
                            <Run Text="Ln" /><Run Text=" " /><Run Text="{Binding Documents.ActiveDocument.CaretLine, Mode=OneWay}" /><Run Text=", Col " /><Run Text="{Binding Documents.ActiveDocument.CaretColumn, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                    <Border Style="{StaticResource StatusPillStyle}">
                        <TextBlock>
                            <Run Text="Spaces: " /><Run Text="{Binding Options.TabWidth, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                    <Border Style="{StaticResource StatusPillStyle}">
                        <TextBlock Text="UTF-8" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================= Workbench (cards on canvas) ============================= -->
        <Grid Margin="8,2,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="260" MinWidth="150" MaxWidth="600" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar card: explorer + search panels -->
            <Border x:Name="SidebarHost"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="10"
                    services:RoundedClip.Radius="10">
                <TabControl x:Name="SidebarTabs" Style="{StaticResource SegmentedTabControlStyle}">
                <TabItem Header="Files" Style="{StaticResource SegmentTabItemStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="&#xE72C;"
                            FontSize="12"
                            ToolTip="Refresh Explorer"
                            HorizontalAlignment="Right"
                            Margin="0,2,6,2"
                            Command="{Binding Explorer.RefreshCommand}">
                        <Button.Visibility>
                            <Binding Path="Explorer.HasWorkspace" Converter="{StaticResource BooleanToVisibilityConverter}" />
                        </Button.Visibility>
                    </Button>

                    <!-- Folder tree (when a workspace is open) -->
                    <TreeView x:Name="ExplorerTree"
                              Grid.Row="1"
                              ItemsSource="{Binding Explorer.Roots}"
                              VirtualizingPanel.IsVirtualizing="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              MouseDoubleClick="OnExplorerTreeMouseDoubleClick"
                              KeyDown="OnExplorerTreeKeyDown">
                        <TreeView.Style>
                            <Style TargetType="TreeView" BasedOn="{StaticResource {x:Type TreeView}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Explorer.HasWorkspace}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.Style>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type vm:FileTreeItemViewModel}" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Background="Transparent">
                                    <Grid Width="16" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding IconGlyph}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UsesLanguageIcon}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding LanguageIconGlyph}"
                                                   FontFamily="{StaticResource Font.Devicon}"
                                                   FontSize="14"
                                                   Foreground="{Binding LanguageIconBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UsesLanguageIcon}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="{Binding Name}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="_Open" Command="{Binding OpenCommand}">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <MenuItem Header="New _File…" Command="{Binding NewFileCommand}">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <MenuItem Header="New Fol_der…" Command="{Binding NewFolderCommand}">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <MenuItem Header="Re_fresh" Command="{Binding RefreshCommand}">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="_Rename…" Command="{Binding RenameCommand}">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRoot}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <MenuItem Header="De_lete" Command="{Binding DeleteCommand}">
                                                <MenuItem.Style>
                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRoot}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </MenuItem.Style>
                                            </MenuItem>
                                            <Separator>
                                                <Separator.Style>
                                                    <Style TargetType="Separator" BasedOn="{StaticResource {x:Static MenuItem.SeparatorStyleKey}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRoot}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Separator.Style>
                                            </Separator>
                                            <MenuItem Header="Copy _Path" Command="{Binding CopyPathCommand}" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                    <!-- Empty state (no workspace open) -->
                    <StackPanel Grid.Row="1" Margin="14,4">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Explorer.HasWorkspace}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock TextWrapping="Wrap"
                                   Opacity="0.6"
                                   Text="You have not yet opened a folder." />
                        <Button Content="Open Folder"
                                Style="{StaticResource DialogButtonStyle}"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Left"
                                Command="{Binding Explorer.OpenFolderCommand}" />
                    </StackPanel>
                </Grid>
                </TabItem>

                <TabItem x:Name="SearchTab" Header="Search" Style="{StaticResource SegmentTabItemStyle}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBox x:Name="SearchQueryBox"
                                 Style="{StaticResource PanelTextBoxStyle}"
                                 Text="{Binding Search.QueryText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Type a search term and press Enter">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding Search.SearchCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                            <ToggleButton Style="{StaticResource SearchOptionToggleStyle}"
                                          Content="Aa"
                                          ToolTip="Match Case"
                                          IsChecked="{Binding Search.MatchCase}" />
                            <ToggleButton Style="{StaticResource SearchOptionToggleStyle}"
                                          Content="Word"
                                          Margin="4,0,0,0"
                                          ToolTip="Match Whole Word"
                                          IsChecked="{Binding Search.WholeWord}" />
                            <Button Style="{StaticResource DialogButtonStyle}"
                                    Content="Search"
                                    Margin="10,0,0,0"
                                    Command="{Binding Search.SearchCommand}" />
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Margin="2,8,0,4"
                                   Opacity="0.7"
                                   TextWrapping="Wrap"
                                   Text="{Binding Search.StatusMessage}" />

                        <TreeView x:Name="SearchResultsTree"
                                  Grid.Row="3"
                                  ItemsSource="{Binding Search.Results}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  KeyDown="OnSearchResultsKeyDown">
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type vm:SearchFileResultViewModel}" ItemsSource="{Binding Matches}">
                                    <StackPanel Orientation="Horizontal" Background="Transparent" ToolTip="{Binding FilePath}">
                                        <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding FileName}" Margin="6,0,0,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding RelativeDirectory}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Opacity="0.55" />
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                                <DataTemplate DataType="{x:Type vm:SearchMatchViewModel}">
                                    <TextBlock Background="Transparent" TextTrimming="CharacterEllipsis">
                                        <TextBlock.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding OpenCommand}" />
                                        </TextBlock.InputBindings>
                                        <!-- Runs must stay adjacent: whitespace between them renders as a space inside the excerpt. -->
                                        <Run Text="{Binding LineNumberDisplay, Mode=OneWay}" Foreground="{DynamicResource Brush.Panel.Header.Foreground}" /><Run Text="{Binding LinePrefix, Mode=OneWay}" /><Run Text="{Binding MatchText, Mode=OneWay}" Background="{DynamicResource Brush.Editor.Selection}" /><Run Text="{Binding LineSuffix, Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </Grid>
                </TabItem>
                </TabControl>
            </Border>

            <GridSplitter x:Name="SidebarSplitter"
                          Grid.Column="1"
                          Width="8"
                          Style="{StaticResource GutterSplitterVerticalStyle}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="100" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="BottomPanelRow" Height="180" MinHeight="80" MaxHeight="500" />
                </Grid.RowDefinitions>

                <!-- Editor card -->
                <Border Background="{DynamicResource Brush.Surface.Editor}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="10"
                        services:RoundedClip.Radius="10">
                <Grid>
                    <TabControl x:Name="DocumentTabs"
                                ItemsSource="{Binding Documents.Documents}"
                                SelectedItem="{Binding Documents.ActiveDocument, Mode=TwoWay}"
                                Background="Transparent">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" ToolTip="{Binding FilePath}">
                                    <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" />
                                    <TextBlock Text="●" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="9"
                                               Foreground="{DynamicResource Brush.Accent}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Style="{StaticResource TabCloseButtonStyle}"
                                            Command="{Binding CloseCommand}"
                                            Margin="8,0,0,0"
                                            ToolTip="Close (Ctrl+W)" />
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <views:EditorView />
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <!-- Welcome hint shown when no document is open -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Documents.Documents.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Width="34"
                                Height="34"
                                CornerRadius="9"
                                Background="{DynamicResource Brush.Accent}"
                                HorizontalAlignment="Center" />
                        <TextBlock Text="Code Editor"
                                   FontSize="22"
                                   FontWeight="Light"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,3" />
                        <TextBlock Text="A quiet place to write code"
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.Text.Muted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,26" />
                        <StackPanel HorizontalAlignment="Center">
                            <StackPanel.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </StackPanel.Resources>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="New file" Foreground="{DynamicResource Brush.Text.Muted}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Style="{StaticResource KeycapStyle}"><TextBlock Text="Ctrl" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" /></Border>
                                    <Border Style="{StaticResource KeycapStyle}"><TextBlock Text="N" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" /></Border>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Open file" Foreground="{DynamicResource Brush.Text.Muted}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Style="{StaticResource KeycapStyle}"><TextBlock Text="Ctrl" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" /></Border>
                                    <Border Style="{StaticResource KeycapStyle}"><TextBlock Text="O" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" /></Border>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Open folder" Foreground="{DynamicResource Brush.Text.Muted}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Style="{StaticResource KeycapStyle}"><TextBlock Text="Ctrl" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" /></Border>
                                    <Border Style="{StaticResource KeycapStyle}"><TextBlock Text="Shift" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" /></Border>
                                    <Border Style="{StaticResource KeycapStyle}"><TextBlock Text="O" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" /></Border>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Find in files" Foreground="{DynamicResource Brush.Text.Muted}" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Style="{StaticResource KeycapStyle}"><TextBlock Text="Ctrl" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" /></Border>
                                    <Border Style="{StaticResource KeycapStyle}"><TextBlock Text="Shift" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" /></Border>
                                    <Border Style="{StaticResource KeycapStyle}"><TextBlock Text="F" FontSize="11" Foreground="{DynamicResource Brush.Text.Secondary}" /></Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Inline find/replace panel (Ctrl+F / Ctrl+H) -->
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,44,22,0"
                            Padding="8"
                            Background="{DynamicResource Brush.Surface.Overlay}"
                            BorderBrush="{DynamicResource Brush.Border.Strong}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="{Binding Find.IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ToggleButton Grid.RowSpan="2"
                                          Style="{StaticResource SearchOptionToggleStyle}"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="10"
                                          VerticalAlignment="Stretch"
                                          Margin="0,0,4,0"
                                          ToolTip="Toggle Replace"
                                          IsChecked="{Binding Find.IsReplaceVisible}">
                                <ToggleButton.Content>&#xE76C;</ToggleButton.Content>
                            </ToggleButton>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="FindTextBox"
                                         Style="{StaticResource PanelTextBoxStyle}"
                                         Width="180"
                                         VerticalAlignment="Center"
                                         Text="{Binding Find.FindText, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding Find.FindNextCommand}" />
                                        <KeyBinding Modifiers="Shift" Key="Return" Command="{Binding Find.FindPreviousCommand}" />
                                        <KeyBinding Key="Escape" Command="{Binding Find.CloseCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <ToggleButton Style="{StaticResource SearchOptionToggleStyle}"
                                              Content="Aa"
                                              Margin="4,0,0,0"
                                              ToolTip="Match Case"
                                              IsChecked="{Binding Find.MatchCase}" />
                                <ToggleButton Style="{StaticResource SearchOptionToggleStyle}"
                                              Content="Word"
                                              Margin="2,0,0,0"
                                              ToolTip="Match Whole Word"
                                              IsChecked="{Binding Find.WholeWord}" />
                                <TextBlock Text="{Binding Find.MatchStatus}"
                                           MinWidth="70"
                                           Margin="8,0"
                                           VerticalAlignment="Center"
                                           Opacity="0.7"
                                           TextTrimming="CharacterEllipsis" />
                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                        Content="&#xE70E;"
                                        FontSize="11"
                                        ToolTip="Previous Match (Shift+F3)"
                                        Command="{Binding Find.FindPreviousCommand}" />
                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                        Content="&#xE70D;"
                                        FontSize="11"
                                        ToolTip="Next Match (F3)"
                                        Command="{Binding Find.FindNextCommand}" />
                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                        Content="&#xE711;"
                                        FontSize="11"
                                        ToolTip="Close (Esc)"
                                        Command="{Binding Find.CloseCommand}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Grid.Row="1"
                                        Orientation="Horizontal"
                                        Margin="0,4,0,0"
                                        Visibility="{Binding Find.IsReplaceVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBox x:Name="ReplaceTextBox"
                                         Style="{StaticResource PanelTextBoxStyle}"
                                         Width="180"
                                         VerticalAlignment="Center"
                                         Text="{Binding Find.ReplaceText, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding Find.ReplaceCommand}" />
                                        <KeyBinding Key="Escape" Command="{Binding Find.CloseCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Style="{StaticResource DialogButtonStyle}"
                                        Content="Replace"
                                        Margin="4,0,0,0"
                                        ToolTip="Replace current match (Enter)"
                                        Command="{Binding Find.ReplaceCommand}" />
                                <Button Style="{StaticResource DialogButtonStyle}"
                                        Content="All"
                                        Margin="4,0,0,0"
                                        ToolTip="Replace all matches"
                                        Command="{Binding Find.ReplaceAllCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                </Border>

                <GridSplitter x:Name="BottomSplitter"
                              Grid.Row="1"
                              Height="8"
                              Style="{StaticResource GutterSplitterHorizontalStyle}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              ResizeBehavior="PreviousAndNext" />

                <!-- Bottom panel card -->
                <Border x:Name="BottomPanelHost"
                        Grid.Row="2"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="10"
                        services:RoundedClip.Radius="10">
                    <TabControl Style="{StaticResource SegmentedTabControlStyle}">
                        <TabItem Header="Output" Style="{StaticResource SegmentTabItemStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Margin="8,6,8,2">
                                    <ComboBox Width="160"
                                              HorizontalAlignment="Left"
                                              ItemsSource="{Binding Output.Channels}"
                                              SelectedItem="{Binding Output.SelectedChannel}"
                                              DisplayMemberPath="Name" />
                                    <Button Style="{StaticResource ToolbarButtonStyle}"
                                            Content="&#xE74D;"
                                            FontSize="12"
                                            ToolTip="Clear Output"
                                            HorizontalAlignment="Right"
                                            Command="{Binding Output.ClearCommand}" />
                                </Grid>

                                <TextBox x:Name="OutputTextBox"
                                         Grid.Row="1"
                                         Text="{Binding Output.Text, Mode=OneWay}"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource Brush.Window.Foreground}"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="12"
                                         Padding="8,2"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextChanged="OnOutputTextChanged" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="Problems" Style="{StaticResource SegmentTabItemStyle}">
                            <Grid>
                                <ListBox x:Name="ProblemsList"
                                         ItemsSource="{Binding Problems.Diagnostics}"
                                         MouseDoubleClick="OnProblemsListMouseDoubleClick"
                                         KeyDown="OnProblemsListKeyDown">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Background="Transparent" ToolTip="{Binding Message}">
                                                <TextBlock x:Name="SeverityGlyph"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Text="&#xE946;"
                                                           Foreground="{DynamicResource Brush.Diagnostic.Info}" />
                                                <TextBlock Text="{Binding Message}"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Source}"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="11"
                                                           Opacity="0.55" />
                                                <TextBlock Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="11"
                                                           Opacity="0.55"><Run Text="{Binding FilePath, Mode=OneWay}" /><Run Text=" (" /><Run Text="{Binding Line, Mode=OneWay}" /><Run Text=", " /><Run Text="{Binding Column, Mode=OneWay}" /><Run Text=")" /></TextBlock>
                                            </StackPanel>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                    <Setter TargetName="SeverityGlyph" Property="Text" Value="&#xE783;" />
                                                    <Setter TargetName="SeverityGlyph" Property="Foreground" Value="{DynamicResource Brush.Diagnostic.Error}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                    <Setter TargetName="SeverityGlyph" Property="Text" Value="&#xE7BA;" />
                                                    <Setter TargetName="SeverityGlyph" Property="Foreground" Value="{DynamicResource Brush.Diagnostic.Warning}" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Margin="10,8"
                                           VerticalAlignment="Top"
                                           Opacity="0.6"
                                           IsHitTestVisible="False"
                                           Text="No problems detected.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Problems.HasDiagnostics}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Terminal" Style="{StaticResource SegmentTabItemStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBox x:Name="TerminalOutputBox"
                                         Text="{Binding Terminal.Text, Mode=OneWay}"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource Brush.Window.Foreground}"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="12"
                                         Padding="8,4"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextChanged="OnTerminalTextChanged" />

                                <!-- Empty-state hint until the shell is started -->
                                <TextBlock Margin="10,8"
                                           VerticalAlignment="Top"
                                           Opacity="0.6"
                                           IsHitTestVisible="False"
                                           Text="Type a command below and press Enter to start the shell.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Terminal.IsRunning}" Value="False" />
                                                        <Condition Binding="{Binding Terminal.Text}" Value="" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Grid Grid.Row="1" Margin="8,2,8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="&gt;"
                                               FontFamily="Cascadia Mono, Consolas"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"
                                               Opacity="0.7" />
                                    <TextBox x:Name="TerminalInputBox"
                                             Grid.Column="1"
                                             Style="{StaticResource PanelTextBoxStyle}"
                                             FontFamily="Cascadia Mono, Consolas"
                                             Text="{Binding Terminal.InputText, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding Terminal.SubmitCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,0,0,0">
                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                Content="&#xE72C;"
                                                FontSize="12"
                                                ToolTip="Restart Shell"
                                                Command="{Binding Terminal.RestartCommand}" />
                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                Content="&#xE74D;"
                                                FontSize="12"
                                                ToolTip="Clear Terminal"
                                                Command="{Binding Terminal.ClearTranscriptCommand}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>

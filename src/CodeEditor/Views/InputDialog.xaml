<Window x:Class="CodeEditor.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.Surface.Overlay}"
        Foreground="{DynamicResource Brush.Window.Foreground}">

    <StackPanel Margin="16,14">
        <TextBlock x:Name="PromptText" TextWrapping="Wrap" />

        <TextBox x:Name="ValueBox"
                 Style="{StaticResource PanelTextBoxStyle}"
                 Margin="0,10,0,0" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK"
                    Style="{StaticResource DialogButtonStyle}"
                    IsDefault="True"
                    MinWidth="80"
                    Click="OnOkClick" />
            <Button Content="Cancel"
                    Style="{StaticResource DialogButtonStyle}"
                    IsCancel="True"
                    MinWidth="80"
                    Margin="8,0,0,0" />
        </StackPanel>
    </StackPanel>
</Window>
